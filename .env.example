# 复制为 .env 并填入真实值(.env 已被 .gitignore 忽略,勿提交)
SILICONFLOW_API_KEY=YOUR_SILICONFLOW_API_KEY
CODEDOC_PG_DSN=host=127.0.0.1 port=5432 dbname=codedoc user=codedoc password=CHANGE_ME_PG_PASSWORD
CODEDOC_INTERNAL_KEY=CHANGE_ME_INTERNAL_KEY
# 多仓多 Agent 单次延迟硬预算(秒)
CODEDOC_MULTI_BUDGET=60
# 本地文件增量同步监听(1 开 / 0 关)
CODEDOC_WATCHDOG=1
